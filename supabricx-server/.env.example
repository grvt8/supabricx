PORT=3000
NODE_ENV=development

DATABASE_URL="postgresql://user:password@localhost:5432/supabricx?schema=public"

GITHUB_CLIENT_ID="your_client_id"
GITHUB_CLIENT_SECRET="your_client_secret"
GITHUB_CALLBACK_URL="http://localhost:3000/auth/github/callback"
GITHUB_TOKEN="your_github_token"

JWT_SECRET="your_super_secret_key_min_32_chars"
JWT_EXPIRATION="7d"
REFRESH_TOKEN_SECRET="your_refresh_secret_key_min_32_chars"
REFRESH_TOKEN_EXPIRATION="30d"

REDIS_HOST="localhost"
REDIS_PORT=6379

AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_key"
AWS_SECRET_ACCESS_KEY="your_secret"
AWS_S3_BUCKET="supabricx-exports"

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET_NAME=supabricx-exports
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-your_account_id.r2.cloudflarestorage.com

# Optional: For signed URLs
R2_SIGNED_URL_EXPIRY=3600


FRONTEND_URL="http://localhost:3001"

OPENAI_API_KEY="your_openai_api_key"
OPENAI_MODEL="gpt-4o"
ANTHROPIC_API_KEY="your_anthropic_api_key"
